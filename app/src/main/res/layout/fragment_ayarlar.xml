<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ayarlar"
            android:textSize="@dimen/text_size_xl"
            android:textStyle="bold"
            android:textColor="?colorPrimary"
            android:layout_marginBottom="@dimen/spacing_16" />

        <!-- Plant Profile Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="?colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bitki Profili"
                    android:textSize="@dimen/text_size_base"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <Spinner
                    android:id="@+id/spinnerPlant"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <TextView
                    android:id="@+id/tvProfileDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="@dimen/text_size_xs"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginBottom="@dimen/spacing_12" />

                <!-- Profil butonları -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnApplyProfile"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="@dimen/spacing_6"
                        android:text="Uygula" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddProfile"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_6"
                        android:layout_marginEnd="@dimen/spacing_6"
                        android:text="+ Yeni" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDeleteProfile"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sil"
                        android:enabled="false"
                        android:textColor="?colorError" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ESP32 Connection Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="?colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ESP32 Baglantisi"
                    android:textSize="@dimen/text_size_base"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="ESP32 IP Adresi"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etIp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:text="192.168.1.100" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Port"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:text="8080" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConnect"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bağlan"
                    android:layout_marginTop="@dimen/spacing_8" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Control Parameters Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            app:cardCornerRadius="@dimen/corner_medium"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="?colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kontrol Parametreleri"
                    android:textSize="@dimen/text_size_base"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Min Sicaklik (C)"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTempMin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="18" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Max Sicaklik (C)"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTempMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="28" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Max Nem (%)"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHumMax"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="80" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Min Toprak Nemi (%)"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSoilMin"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="30" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Elektrik Fiyati (TL/kWh)"
                    android:layout_marginBottom="@dimen/spacing_8">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:text="4.60" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kaydet"
            android:layout_marginBottom="@dimen/spacing_16" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
