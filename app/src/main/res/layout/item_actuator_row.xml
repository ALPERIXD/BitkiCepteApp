<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="@dimen/corner_medium"
    app:cardElevation="0dp"
    app:strokeWidth="@dimen/card_stroke_width"
    app:strokeColor="?colorOutline">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_12">

        <!-- Label + Duty% + Switch row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/spacing_8">

            <ImageView
                android:id="@+id/ivActuatorIcon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="@dimen/spacing_8"
                android:src="@drawable/ic_fan"
                android:contentDescription="@null"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/tvActuatorLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Isitici"
                android:textSize="@dimen/text_size_base"
                android:textStyle="bold"
                android:textColor="?colorOnSurface" />

            <TextView
                android:id="@+id/tvActuatorDuty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="@dimen/text_size_sm"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="?colorPrimary"
                android:layout_marginEnd="@dimen/spacing_8" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchActuator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- Duty Slider -->
        <com.google.android.material.slider.Slider
            android:id="@+id/sliderActuator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            android:stepSize="1"
            android:value="0" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
