<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_16">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enerji Analizi"
            android:textSize="@dimen/text_size_xl"
            android:textStyle="bold"
            android:textColor="?colorPrimary"
            android:layout_marginBottom="@dimen/spacing_16" />

        <!-- KPI Row: Consumption + Solar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_8">

            <include
                android:id="@+id/kpiConsumption"
                layout="@layout/item_kpi_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_6" />

            <include
                android:id="@+id/kpiSolar"
                layout="@layout/item_kpi_card"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_6" />

        </LinearLayout>

        <!-- KPI: Saving -->
        <include
            android:id="@+id/kpiSaving"
            layout="@layout/item_kpi_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16" />

        <!-- Weekly Bar Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_12"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="?colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Haftalik Tuketim (kWh)"
                    android:textSize="@dimen/text_size_base"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <com.github.mikephil.charting.charts.BarChart
                    android:id="@+id/barChartWeek"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Daily Breakdown Pie Chart -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_16"
            app:cardCornerRadius="@dimen/corner_large"
            app:cardElevation="@dimen/card_elevation"
            app:strokeWidth="@dimen/card_stroke_width"
            app:strokeColor="?colorOutline">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bugun Dagilim"
                    android:textSize="@dimen/text_size_base"
                    android:textStyle="bold"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="@dimen/spacing_8" />

                <com.github.mikephil.charting.charts.PieChart
                    android:id="@+id/pieChart"
                    android:layout_width="match_parent"
                    android:layout_height="220dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
