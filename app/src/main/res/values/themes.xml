<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.BitkiCepteApp" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_green</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryContainer">@color/brand_green_50</item>
        <item name="colorOnPrimaryContainer">@color/brand_green</item>
        <item name="colorSecondary">@color/tech_blue</item>
        <item name="colorTertiary">@color/sun_yellow</item>
        <item name="colorError">@color/color_bad</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_3_light</item>
        <item name="colorOnSurface">@color/text_primary_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary_light</item>
        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorOutline">@color/outline_light</item>
        <item name="colorOutlineVariant">@color/outline_2_light</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.BitkiCepte.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.BitkiCepte.Large</item>
    </style>
    <style name="ShapeAppearance.BitkiCepte.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">14dp</item>
    </style>
    <style name="ShapeAppearance.BitkiCepte.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">20dp</item>
    </style>
</resources>
